{
  "routes": [
    {
      "route": "/dashboard/*",
      "requiredHeaders": {
        "X-Dead-Drop-Token": "OMEGA_"
      },
      "serve": "/dashboard.html",
      "statusCode": 302,
      "statusCodeExpression": "$request.headers['X-Dead-Drop-Token'] != 'OMEGA_'"
    },
    {
      "route": "/gatekeeper",
      "serve": "/index.html"
    },
    {
      "route": "/drop",
      "methods": ["POST", "OPTIONS"],
      "headers": {
        "Access-Control-Allow-Origin": "*",
        "Access-Control-Allow-Methods": "POST, OPTIONS",
        "Access-Control-Allow-Headers": "Content-Type, X-Session-ID, X-CSRF-Token",
        "Access-Control-Max-Age": "86400"
      },
      "serve": false
    },
    {
      "route": "/beacon",
      "methods": ["POST"],
      "headers": {
        "Access-Control-Allow-Origin": "*"
      },
      "serve": false
    },
    {
      "route": "/aps",
      "methods": ["POST"],
      "headers": {
        "Access-Control-Allow-Origin": "*",
        "Access-Control-Allow-Methods": "POST, OPTIONS",
        "Access-Control-Allow-Headers": "Content-Type, X-Session-ID"
      },
      "serve": false
    },
    {
      "route": "/ux_optimizer.js",
      "serve": "/ux_optimizer.js",
      "headers": {
        "Content-Type": "application/javascript; charset=utf-8",
        "Cache-Control": "public, max-age=3600, immutable",
        "X-Content-Type-Options": "nosniff"
      }
    },
    {
      "route": "/pixel",
      "methods": ["GET"],
      "serve": "/pixel.gif",
      "headers": {
        "Content-Type": "image/gif",
        "Cache-Control": "no-store, no-cache, must-revalidate",
        "Pragma": "no-cache"
      }
    }
  ],
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": ["/api/*", "/dashboard/*", "/drop", "/beacon", "/aps"]
  },
  "globalHeaders": {
    "X-Frame-Options": "DENY",
    "X-Content-Type-Options": "nosniff",
    "Content-Security-Policy": "default-src 'self'"
  }
}
